# Chirp Gold Payments · Vercel Environment Variables

# URL pública de tu deploy. En producción: https://chirp.com.ar
PUBLIC_SITE_URL=https://chirp.com.ar

# Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Mercado Pago
# Test: TEST-...
# Producción: APP_USR-...
# PUBLIC_KEY puede ser no-sensitive; ACCESS_TOKEN y WEBHOOK_SECRET son sensitive.
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=PEGAR_SECRET_DEL_WEBHOOK
MP_GOLD_MONTHLY_PRICE_ARS=3490
MP_GOLD_MONTHLY_CURRENCY=ARS

# PayPal
# sandbox o live
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=TU_PAYPAL_CLIENT_SECRET
PAYPAL_WEBHOOK_ID=WH-xxxxxxxxxxxxxxxxx
PAYPAL_GOLD_MONTHLY_PRICE_USD=4.99
PAYPAL_GOLD_MONTHLY_CURRENCY=USD

# Plan
CHIRP_GOLD_MONTHLY_DAYS=30
