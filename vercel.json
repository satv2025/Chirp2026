{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/u/:username", "destination": "/u/index.html" },
    { "source": "/chirp/:id", "destination": "/chirp/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
